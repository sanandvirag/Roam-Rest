<% layout("/layouts/boilerplate.ejs") %>
<% block('styles').append(`<link rel="stylesheet" href="/listings.css">`) %>
<% let arr = sample_data %>

<style>
  #filters {
    display: flex;
    align-items: center;
    justify-content: space-evenly; 
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .filters-left {
    display: flex;
    align-items: center;
    gap: 2rem; 
    flex-wrap: wrap; 
  }

  .filter {
    display: flex;
    flex-direction: column; 
    align-items: center;    
    justify-content: center;
    opacity: 0.75;
    cursor: pointer;
  }

  
  .filter p {
    margin: 0; 
    margin-top: 0.25rem; 
     
  }

  .filter:hover {
    opacity: 1;
  }

  .tax {
    display: none;
  }

  .tax-toggle {
    border: 1px solid black;
    border-radius: 14px;
    padding: 0.5rem 0.8rem;
  }
</style>
<div id="filters">
  <div class="filters-left">
    <div class="filter">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-bed"></i>
      <p>Rooms</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-city"></i>
      <p>Iconic cities</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountains</p>
    </div>
    <div class="filter">
      <i class="fa-brands fa-fort-awesome"></i>
      <p>Castel</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Amazing pools</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-snowman"></i>
      <p>Artic</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-umbrella-beach"></i>
      <p>Beaches</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-tractor"></i>
      <p>Farms</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-dog"></i>
      <p>Pet-friendly</p>
    </div>
    <div class="filter">
      <i class="fa-solid fa-building"></i>
      <p>Unique stays</p>
    </div>
  </div>
  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
      <label class="form-check-label" for="flexSwitchCheckDefault">Display Taxes</label>
    </div>
  </div>
</div>
<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 mt-3">
  <% for(let i=0 ; i<arr.length ; i++){ %>
    <div class="card">
      <a href="/listings/<%= arr[i].id%>" class="view">
        <img 
          src="<%= arr[i].image?.url || 'https://www.buyrentkenya.com/discover/wp-content/uploads/2022/06/brk-blog-4reasons-why.png' %>" 
          class="card-img-top" 
          alt="<%= arr[i].title || 'Listing image' %>"
        >
        <div class="card-body">
          <p class="card-text title"><%= arr[i].title %></p>
          <p class="card-text price"> &#8377;<%= arr[i].price %> per night<i class="tax">&nbsp;&nbsp;&nbsp; +18% GST </i></p>
          
        </div>
      </a>
    </div>
  <% } %> 
</div>

<script>
  let taxSwitch = document.getElementById("flexSwitchCheckDefault");
  taxSwitch.addEventListener("click" , ()=>{
    let taxInfo = document.getElementsByClassName("tax");
    for(info of taxInfo){
      if(info.style.display === "inline"){
        info.style.display = "none"
      }
      else{
        info.style.display = "inline";
      }
    }
  });
</script>

