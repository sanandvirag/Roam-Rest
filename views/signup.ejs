<% layout("/layouts/boilerplate.ejs") %>
<% block('styles').append(`<link rel="stylesheet" href="/edit.css">`) %>

<div>
  <h1 class="offset-5 col-6 mt-4">Sign Up</h1>
  <h5 class="offset-5 col-6">Home Hopper</h5>
  <div class="row">
    <form class="offset-3 col-6  needs-validation" method="POST" action="/signup" novalidate>
    <div class="form-group mb-3">
      <label for="username">Username</label>
      <input type="text" class="form-control" id="username" name="username" required>
    </div>
    <div class="form-group mb-3">
      <label for="email">Email address</label>
      <input type="email" class="form-control" id="email" name="email" required>
    </div>
    <div class="form-group mb-3">
      <label for="password">Password</label>
      <input type="password" class="form-control" id="password" name="password" required>
    </div>
    <button type="submit" class="btn btn-primary">Sign Up</button>
    </form>
  </div>
</div>
