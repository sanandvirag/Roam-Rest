<% layout("/layouts/boilerplate.ejs") %>
<% block('styles').append(`<link rel="stylesheet" href="/info.css">`) %>

<script>
  const mapToken = "<%= process.env.MAP_TOKEN %>";
  const coordinates = <%- JSON.stringify(info.geometry.coordinates) %>;
</script>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card listing-card mb-3">
        <img src="<%= info.image.url %>" class="card-img-top listing-img" alt="<%= info.title %>">
        <div class="card-body p-4">
          <h2 class="card-title mb-3"><%= info.title %></h2>
          <p class="card-text description"><%= info.description %></p>
          <p><b>&#8377;<%= info.price %></b></p>
          <p class="location"><%= info.location %>, <%= info.country %></p>
          <p>Owner: <i><%= info.owner.username %></i></p>
          <% if(currUser && info.owner._id.equals(currUser._id)){ %>
            <hr>
            <div class="button-group">
              <form action="/listings/<%= info.id %>/edit" method="GET">
                <button class="btn btn-dark px-4" type="submit">Edit</button>
              </form>
              <form action="/listings/<%= info.id %>?_method=DELETE" method="POST">
                <button class="btn btn-danger px-4" type="submit">Delete</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
      <div class="review_sys">
        <% if(currUser){ %>
          <div class="mt-3 mb-3 my_review">
            <form action="/listings/<%= info.id %>/review" method="POST" novalidate class="needs-validation">
              <div class="mb-3">
                <h3>Leave a Review</h3>
                <div>
                  <fieldset class="starability-basic">
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                  </fieldset>
                </div>
                <div class="mb-3">
                  <label for="comment" class="form-label validate">Comment</label>
                  <textarea class="form-control" name="review[comment]" id="comment" rows="4" required="true"></textarea>
                </div>
              </div>
              <button class="btn btn-outline-dark px-4" type="submit">Submit</button>
            </form>
          </div>
        <% } %>
        <% if(info.reviews.length > 0){ %>
          <div class="other_review">
            <h4>Reviews</h4>
            <div class="row g-4">
              <% for(let i=0 ; i<info.reviews.length ; i++){ %>
                <div class="col-6">
                  <div class="each_review card p-3">
                    <img class="profile_pic" src="/icons8-customer-96.png" alt="">
                    <h6 class="username"><%= info.reviews[i].author.username %></h6>
                    <p class="review_date"><%= info.reviews[i].createdAt.toLocaleString('en-US', {day:'numeric', month: 'short', year: 'numeric' }) %></p>
                    <p class="starability-result" data-rating="<%= info.reviews[i].rating %>"></p>
                    
                    <p class="comment"><%= info.reviews[i].comment %></p>
                    <% if(currUser && info.reviews[i].author._id.equals(currUser._id)){ %>
                      <form action="/listings/<%= info._id %>/review/<%= info.reviews[i]._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-sm btn-dark">Delete</button>
                      </form>
                    <% } %>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
      <hr>
      <div class="col-lg-8 mb-3">
        <h5>Where you'll be</h5>
        <div id="map"></div>
      </div>
    </div>
  </div>
</div>

<script src="/map.js"></script>


