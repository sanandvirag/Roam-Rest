<% layout("/layouts/boilerplate.ejs") %>
<% block('styles').append(`<link rel="stylesheet" href="/info.css">`) %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card listing-card mb-3">
        <img
          src="<%= info.image?.url || 'https://www.buyrentkenya.com/discover/wp-content/uploads/2022/06/brk-blog-4reasons-why.png' %>"
          onerror="this.onerror=null; this.src='https://www.buyrentkenya.com/discover/wp-content/uploads/2022/06/brk-blog-4reasons-why.png';"
          class="card-img-top listing-img"
          alt="<%= info.title || 'Listing image' %>"
        >
        <div class="card-body p-4">
          <h2 class="card-title mb-3"><%= info.title %></h2>
          <p class="card-text description"><%= info.description %></p>
          <p><b>&#8377;<%= info.price %></b></p>
          <p class="location"><%= info.location %>, <%= info.country %></p>
          <p>Owner: <i><%= info.owner.username %></i></p>
          <% if(currUser && info.owner._id.equals(currUser._id)){ %>
            <hr>
            <div class="button-group">
              <form action="/listings/<%= info.id %>/edit" method="GET">
                <button class="btn btn-dark px-4" type="submit">Edit</button>
              </form>
              <form action="/listings/<%= info.id %>?_method=DELETE" method="POST">
                <button class="btn btn-danger px-4" type="submit">Delete</button>
              </form>
            </div>
          <% } %>
        </div>
      </div>
      <div class="review_sys">
        <% if(currUser){ %>
          <div class="mt-3 mb-3 my_review">
            <form action="/listings/<%= info.id %>/review" method="POST" novalidate class="needs-validation">
              <div class="">
                <h3>Leave a Review</h3>
                <div class="mb-3">
                  <label for="rating" class="form-label">Rating</label>
                  <input class="form-range" type="range" id="rating" min="1" max="5" name="review[rating]">
                </div>
                <div class="mb-3">
                  <label for="comment" class="form-label validate">Comment</label>
                  <textarea class="form-control" name="review[comment]" id="comment" rows="4" required></textarea>
                </div>
              </div>
              <button class="btn btn-outline-dark px-4" type="submit">Submit</button>
            </form>
          </div>
        <% } %>
        <% if(info.reviews.length > 0){ %>
          <div class="other_review">
            <h4>Reviews</h4>
            <div class="row g-4">
              <% for(let i=0 ; i<info.reviews.length ; i++){ %>
                <div class="col-6">
                  <div class="each_review card p-3">
                    <img class="profile_pic" src="/icons8-customer-96.png" alt="">
                    <h6 class="username"><%= info.reviews[i].author.username %></h6>
                    <p class="review_date"><%= info.reviews[i].createdAt.toLocaleString('en-US', { month: 'short', year: 'numeric' }) %></p>
                    <p><%= info.reviews[i].rating %> Star</p>
                    <p class="comment"><%= info.reviews[i].comment %></p>
                    <% if(currUser && info.reviews[i].author._id.equals(currUser._id)){ %>
                      <form action="/listings/<%= info._id %>/review/<%= info.reviews[i]._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-sm btn-dark">Delete</button>
                      </form>
                    <% } %>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>




